{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "malipang-backend-v5-2",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-20",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": { "enabled": true, "head_sampling_rate": 1 },
  "ai": { "binding": "AI" },
  "d1_databases": [{
    "binding": "DB",
    "database_name": "malipang-v5-2",
    "database_id": "1a0744d4-5df7-41e9-b92d-4ccb732ac77a",
    "migrations_dir": "migrations"
  }],
  "r2_buckets": [{ "binding": "EVIDENCE", "bucket_name": "malipang-v5-evidence" }],
  "durable_objects": { "bindings": [{ "name": "ATTENDANCE_COORDINATOR", "class_name": "AttendanceCoordinator" }] },
  "migrations": [{ "tag": "v1", "new_sqlite_classes": ["AttendanceCoordinator"] }],
  "queues": {
    "producers": [{ "binding": "JOB_QUEUE", "queue": "malipang-jobs" }],
    "consumers": [
      {
        "queue": "malipang-jobs",
        "max_batch_size": 10,
        "max_batch_timeout": 2,
        "max_retries": 5,
        "dead_letter_queue": "malipang-jobs-dlq"
      },
      {
        "queue": "malipang-jobs-dlq",
        "max_batch_size": 10,
        "max_batch_timeout": 5,
        "max_retries": 3
      }
    ]
  },
  "triggers": { "crons": ["*/5 * * * *"] },
  "vars": {
    "APP_ENV": "production",
    "RUNTIME_MODE": "shadow",
    "TIMEZONE": "Asia/Bangkok",
    "ATTENDANCE_ENABLED": "true",
    "EXPENSE_ENABLED": "false",
    "SHEETS_SYNC_ENABLED": "true",
    "R2_EVIDENCE_ENABLED": "true",
    "LINE_LOADING_ENABLED": "true",
    "LINE_LOADING_SECONDS": "20",
    "SHADOW_LINE_OUTPUT": "false",
    "WORKERS_AI_ENABLED": "false",
    "WORKERS_AI_MODEL": "@cf/moondream/moondream3.1-9B-A2B",
    "OPENAI_FALLBACK_ENABLED": "true",
    "OPENAI_MODEL": "gpt-4.1-mini",
    "OPENAI_DAILY_FALLBACK_LIMIT": "25",
    "CLOCK_PRIMARY_MIN_CONFIDENCE": "0.97",
    "CLOCK_FALLBACK_MIN_CONFIDENCE": "0.90",
    "CLOCK_MAX_DATE_DIFF_DAYS": "1",
    "CLOCK_MAX_LINE_TIME_DIFF_MIN": "30",
    "EXTERNAL_API_TIMEOUT_MS": "15000",
    "VISION_TIMEOUT_MS": "45000",
    "SHEET_STAFF_CONFIG": "HR_STAFF_CONFIG",
    "SHEET_ATTENDANCE_RAW": "V52_ATTENDANCE_RAW",
    "SHEET_DAILY_PAYROLL": "V52_DAILY_PAYROLL",
    "SHEET_WEEKLY_PAYROLL": "V52_WEEKLY_PAYROLL",
    "SHEET_EXPENSE_RAW": "V52_EXPENSE_RAW",
    "SHEET_SYSTEM_LOG": "V52_SYSTEM_LOG"
  }
}
